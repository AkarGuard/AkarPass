# ─── Supabase (public / anon key — safe to share) ────────────────────────────
# Create a free project at https://supabase.com
# Then copy the URL and anon key from Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Desktop app (Tauri / Vite) ───────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# NOTE: The zero-knowledge architecture means the server never holds encryption
# keys — only an opaque encrypted blob. You do NOT need a service-role key.
