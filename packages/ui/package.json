{
  "name": "@akarpass/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared React UI components for AkarPass",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@akarpass/core": "workspace:*",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "typescript": "5.6.3"
  },
  "peerDependencies": {
    "react": "18.3.1"
  }
}
